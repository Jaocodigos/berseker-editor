datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Character {
  id       Int      @id @default(autoincrement())
  nome     String
  maxHp    Int      @default(0) @map("max_hp")
  actualHp Int      @default(0) @map("actual_hp")
  xp       Int      @default(0)
  pillars  Pillar[]  // um personagem pode ter vários pilares (até 3 na lógica da aplicação)

  @@map("characters") // renomeia a tabela no banco para "characters"
}

model Pillar {
  id          Int       @id @default(autoincrement())
  nome        String
  tipo        String
  maxMana     Int       @default(0) @map("max_mana")
  actualMana  Int       @default(0) @map("actual_mana")
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId Int
  abilities   Ability[]

  @@map("pillar")
}

model Ability {
  id       Int     @id @default(autoincrement())
  nome     String
  descricao String
  dano     String
  custo    Int
  pillar   Pillar @relation(fields: [pillarId], references: [id], onDelete: Cascade)
  pillarId Int

  @@map("ability")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  sessions     Session[]

  @@map("users")
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}
